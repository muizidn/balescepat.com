---
import Layout from '../layouts/Layout.astro';
import { 
	Bot, 
	Code2, 
	LayoutDashboard, 
	GraduationCap, 
	Network, 
	BookOpen, 
	ArrowRight,
	Calendar
} from 'lucide-astro';
---

<Layout title="Balescepat.com | Enterprise AI & Software Solutions">
	<nav>
		<div class="container nav-content">
			<div class="logo">balescepat<span>.</span></div>
			<div class="nav-links">
				<a href="#offerings">Offerings</a>
				<a href="#expertise">Expertise</a>
				<a href="#process">Our Process</a>
				<a href="#contact">Contact</a>
			</div>
			<div class="nav-actions">
				<button class="btn btn-primary">Book Consultation</button>
			</div>
		</div>
	</nav>

	<main>
		<!-- Hero Section -->
		<section class="hero">
			<div class="container hero-content">
				<div class="badge-pill">
					<span class="badge-new">Enterprise</span>
					<span class="badge-text">Bespoke Software & AI Engineering</span>
					<ArrowRight size={14} />
				</div>
				<h1>Building the future of <span>Digital</span> infrastructure</h1>
				<p>Expert consulting and high-performance software engineering. We help teams scale with proprietary AI, custom proxies, and enterprise-grade tools.</p>
				<div class="hero-actions">
					<button class="btn btn-primary btn-lg">Consult with Us</button>
					<button class="btn btn-outline btn-lg">View Our Work</button>
				</div>
			</div>
		</section>

		<!-- Service Offerings Grid -->
		<section id="offerings" class="features">
			<div class="container">
				<div class="section-badge">CORE OFFERINGS</div>
				<div class="section-title">
					<h2>Proprietary solutions for <span>modern</span> enterprises</h2>
					<p>From custom AI development to high-bandwidth network infrastructure, we build the tools that power growing organizations.</p>
				</div>
				<div class="features-grid">
					<div class="feature-card">
						<div class="icon-wrap"><Bot /></div>
						<h3>Whitelabel Customer Service AI</h3>
						<p>Own your infrastructure. We build custom-tuned AI support agents deployed on your own servers with your branding.</p>
					</div>
					<div class="feature-card">
						<div class="icon-wrap"><Code2 /></div>
						<h3>Enterprise Software Development</h3>
						<p>Bespoke web, mobile, and desktop applications built with scale, security, and maintainability as first-class citizens.</p>
					</div>
					<div class="feature-card">
						<div class="icon-wrap"><LayoutDashboard /></div>
						<h3>AI Operating System Dashboard</h3>
						<p>A centralized command center to monitor, manage, and orchestrate all your AI agents and automated workflows.</p>
					</div>
					<div class="feature-card">
						<div class="icon-wrap"><GraduationCap /></div>
						<h3>Software Developer Training</h3>
						<p>Upskill your engineering team with intensive workshops on modern stacks, architecture, and AI-assisted coding.</p>
					</div>
					<div class="feature-card">
						<div class="icon-wrap"><Network /></div>
						<h3>HTTP Network Traffic Proxy</h3>
						<p>High-performance proxy solutions designed for developer teams needing secure, manageable network interception.</p>
					</div>
					<div class="feature-card">
						<div class="icon-wrap"><BookOpen /></div>
						<h3>Enterprise LMS Solutions</h3>
						<p>Custom Learning Management Systems tailored for corporate HR training, professional development, or educational institutions.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Expertise Section -->
		<section id="expertise" class="expertise">
			<div class="container">
				<div class="section-badge">EXPERTISE</div>
				<div class="section-title">
					<h2>Technical excellence at <span>every</span> layer</h2>
					<p>We leverage a modern tech stack to build resilient, high-performance systems for global scale.</p>
				</div>
				<div class="expertise-grid">
					<div class="exp-item">
						<h4>AI & LLM Engineering</h4>
						<p>Experience in RAG pipelines, model fine-tuning (Olama, OpenAI, Anthropic), and specialized agentic workflows.</p>
						<div class="tech-tags">
							<span>Python</span><span>PyTorch</span><span>LangChain</span>
						</div>
					</div>
					<div class="exp-item">
						<h4>High-Performance Systems</h4>
						<p>Building massive throughput backends and network proxies with focus on sub-millisecond latency.</p>
						<div class="tech-tags">
							<span>Bun</span><span>Go</span><span>Rust</span><span>C++</span>
						</div>
					</div>
					<div class="exp-item">
						<h4>Cloud Infrastructure</h4>
						<p>Deployment specialists for on-premise, edge computing, and hybrid cloud architectures.</p>
						<div class="tech-tags">
							<span>Kubernetes</span><span>Docker</span><span>Terraform</span>
						</div>
					</div>
					<div class="exp-item">
						<h4>Modern Web & Mobile</h4>
						<p>Creating immersive, ultra-fast interfaces that provide a premium experience across all devices.</p>
						<div class="tech-tags">
							<span>Astro</span><span>React</span><span>TypeScript</span><span>Vite</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Our Process Section -->
		<section id="process" class="process dark-section">
			<div class="container">
				<div class="section-badge">OUR PROCESS</div>
				<div class="section-header-center">
					<h2 style="color: white;">How we bring your <span>vision</span> to life</h2>
				</div>
				<div class="process-steps">
					<div class="step">
						<div class="step-num">01</div>
						<h4>Discovery & Strategy</h4>
						<p>We start by understanding your business goals and technical roadblocks through deep-dive sessions.</p>
					</div>
					<div class="step">
						<div class="step-num">02</div>
						<h4>Architecture Blueprint</h4>
						<p>Our engineers design a tailor-made technical architecture focused on scalability and security.</p>
					</div>
					<div class="step">
						<div class="step-num">03</div>
						<h4>Agile Execution</h4>
						<p>Rapid, high-quality development with transparent updates and iterative feedback loops.</p>
					</div>
					<div class="step">
						<div class="step-num">04</div>
						<h4>Deployment & Scale</h4>
						<p>We deploy to your infrastructure and provide the training needed to manage your new systems.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Dark Testimonials Section -->
		<section id="testimonials" class="testimonials dark-section">
			<div class="container">
				<div class="testimonial-header">
					<div class="section-badge">TESTIMONIALS</div>
					<h2>What leaders are <span>saying</span></h2>
				</div>
				<div class="testimonial-grid">
					<div class="testimonial-card">
						<div class="stars">★★★★★</div>
						<p>"Balescepat transformed our support overnight. We went from a 4-hour response time to 2 minutes without hiring a single person."</p>
						<div class="author">
							<div class="u-avatar"></div>
							<div class="u-info">
								<strong>Alex Rivera</strong>
								<span>CTO at FinTechly</span>
							</div>
						</div>
					</div>
					<div class="testimonial-card">
						<div class="stars">★★★★★</div>
						<p>"The best investment we've made this year. The ROI was clear within the first week of implementation."</p>
						<div class="author">
							<div class="u-avatar"></div>
							<div class="u-info">
								<strong>Sarah Jenkins</strong>
								<span>Head of Ops at CloudScale</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

	<!-- Final CTA -->
		<section id="contact" class="cta-section">
			<div class="container">
				<div class="cta-wrapper">
					<div class="section-badge">READY TO START?</div>
					<h2>Let's build your <span>next</span> big thing</h2>
					<p>Schedule a 30-minute discovery call to discuss your project requirements and how we can help you scale.</p>
					<div class="cta-btns">
						<button class="btn btn-primary btn-lg"><Calendar style="margin-right: 10px;" size={18} /> Book a Consultation</button>
						<button class="btn btn-outline btn-lg">Email our Team</button>
					</div>
				</div>
			</div>
		</section>
	</main>

	<footer>
		<div class="container">
			<div class="footer-grid">
				<div class="f-brand">
					<div class="logo">balescepat<span>.</span></div>
					<p>Engineering excellence in AI and Enterprise infrastructure.</p>
				</div>
				<div class="f-links">
					<div class="link-col">
						<h4>Expertise</h4>
						<a href="#">AI Development</a>
						<a href="#">Software Eng.</a>
						<a href="#">Security</a>
					</div>
					<div class="link-col">
						<h4>Offerings</h4>
						<a href="#">Whitelabel AI</a>
						<a href="#">Training</a>
						<a href="#">LMS Systems</a>
					</div>
					<div class="link-col">
						<h4>Connect</h4>
						<a href="#">LinkedIn</a>
						<a href="#">GitHub</a>
						<a href="#">Contact</a>
					</div>
				</div>
			</div>
			<div class="footer-bottom">
				<p>&copy; 2024 PT Balescepat Teknologi Nusantara. All rights reserved.</p>
				<div class="socials">
					<a href="#">TW</a>
					<a href="#">LI</a>
					<a href="#">IG</a>
				</div>
			</div>
		</div>
	</footer>
</Layout>

<style>
	/* Navigation */
	nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		background: rgba(255, 255, 255, 0.8);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
		z-index: 1000;
		height: 72px;
		display: flex;
		align-items: center;
	}

	.nav-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
		width: 100%;
	}

	.logo {
		font-size: 1.5rem;
		font-weight: 800;
		letter-spacing: -0.05em;
	}

	.logo span {
		color: var(--accent);
	}

	.nav-links {
		display: flex;
		gap: 2.5rem;
	}

	.nav-links a {
		font-size: 0.95rem;
		font-weight: 500;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.2s;
	}

	.nav-links a:hover {
		color: var(--primary);
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.login {
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
		color: var(--primary);
	}

	/* Hero Section */
	.hero {
		padding: 10rem 0 6rem;
		text-align: center;
	}

	.badge-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		background: #F3F4F6;
		padding: 0.4rem 0.4rem 0.4rem 0.5rem;
		border-radius: 9999px;
		margin-bottom: 2rem;
		border: 1px solid var(--border);
	}

	.badge-new {
		background: var(--primary);
		color: white;
		font-size: 0.75rem;
		font-weight: 700;
		padding: 0.2rem 0.6rem;
		border-radius: 9999px;
	}

	.badge-text {
		font-size: 0.85rem;
		font-weight: 500;
	}

	.hero h1 {
		font-size: clamp(3rem, 10vw, 5.5rem);
		max-width: 900px;
		margin: 0 auto 1.5rem;
	}

	.hero h1 span {
		color: var(--accent);
	}

	.hero p {
		font-size: clamp(1.1rem, 3vw, 1.35rem);
		max-width: 650px;
		margin: 0 auto 3rem;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
	}

	.btn-lg {
		padding: 1rem 2.2rem;
		font-size: 1.05rem;
	}

	/* Globe Visual */
	.hero-visual {
		margin-top: 5rem;
		position: relative;
		height: 450px;
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.glow-sphere {
		position: absolute;
		width: 600px;
		height: 600px;
		background: radial-gradient(circle, var(--glow) 0%, transparent 70%);
		z-index: -1;
	}

	.globe-wrap {
		width: 450px;
		height: 450px;
		animation: float 6s ease-in-out infinite;
	}

	.globe-svg {
		width: 100%;
		height: 100%;
		filter: drop-shadow(0 0 20px rgba(67, 97, 238, 0.1));
		animation: rotate 30s linear infinite;
	}

	@keyframes float {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-20px); }
	}

	@keyframes rotate {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	/* Trust Marquee */
	.trust-marquee {
		padding: 4rem 0;
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
		background: #FAFAFA;
	}

	.trust-marquee p {
		text-align: center;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.2rem;
		margin-bottom: 2.5rem;
	}

	.logo-row {
		display: flex;
		justify-content: space-around;
		align-items: center;
		opacity: 0.4;
	}

	.brand {
		font-weight: 900;
		font-size: 1.5rem;
		letter-spacing: -0.05em;
	}

	/* Features */
	.section-badge {
		color: var(--accent);
		font-weight: 800;
		font-size: 0.8rem;
		letter-spacing: 0.15em;
		margin-bottom: 1.5rem;
	}

	.section-title {
		margin-bottom: 5rem;
	}

	.section-header-center {
		text-align: center;
		margin-bottom: 5rem;
	}

	.section-title h2 {
		font-size: clamp(2.5rem, 5vw, 3.5rem);
		margin-bottom: 1.5rem;
	}

	.section-title h2 span {
		color: var(--accent);
	}

	.section-title p {
		font-size: 1.25rem;
		max-width: 700px;
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.feature-card {
		padding: 3rem;
		border: 1px solid var(--border);
		border-radius: 32px;
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		background: white;
	}

	.feature-card:hover {
		transform: translateY(-8px);
		box-shadow: var(--card-shadow);
		border-color: #EEE;
	}

	.icon-wrap {
		width: 56px;
		height: 56px;
		background: #F3F4F6;
		border-radius: 16px;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 2rem;
		color: var(--accent);
	}

	.feature-card h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}

	/* Testimonials */
	.dark-section {
		background: var(--primary);
		color: white;
		border-radius: 64px;
		margin: 2rem;
		padding: 10rem 0;
	}

	.testimonial-header {
		text-align: center;
		margin-bottom: 6rem;
	}

	.testimonial-header h2 {
		font-size: clamp(2.5rem, 5vw, 3.5rem);
	}

	.testimonial-header h2 span {
		color: var(--accent);
	}

	.testimonial-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2.5rem;
	}

	.testimonial-card {
		padding: 3.5rem;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 32px;
	}

	.stars {
		color: var(--accent);
		margin-bottom: 2rem;
		font-size: 1.2rem;
	}

	.testimonial-card p {
		font-size: 1.5rem;
		color: white;
		line-height: 1.4;
		margin-bottom: 3rem;
	}

	.author {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.u-avatar {
		width: 52px;
		height: 52px;
		background: #333;
		border-radius: 50%;
	}

	.u-info strong {
		display: block;
		font-size: 1.1rem;
	}

	.u-info span {
		font-size: 0.9rem;
		opacity: 0.6;
	}

	/* CTA Section */
	.cta-section {
		padding: 12rem 0;
	}

	.cta-wrapper {
		background: linear-gradient(135deg, #F9FAFB 0%, #FFFFFF 100%);
		padding: 8rem 4rem;
		border-radius: 64px;
		text-align: center;
		border: 1px solid var(--border);
	}

	.cta-wrapper h2 {
		font-size: clamp(2.5rem, 5vw, 4rem);
		margin-bottom: 1.5rem;
	}

	.cta-wrapper p {
		font-size: 1.35rem;
		margin-bottom: 3rem;
	}

	.cta-btns {
		display: flex;
		gap: 1rem;
		justify-content: center;
	}

	/* Footer */
	footer {
		padding: 6rem 0 3rem;
		border-top: 1px solid var(--border);
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 2fr 3fr;
		gap: 4rem;
		margin-bottom: 6rem;
	}

	.f-brand p {
		margin-top: 1.5rem;
		max-width: 300px;
	}

	.f-links {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.link-col h4 {
		font-size: 0.95rem;
		margin-bottom: 1.5rem;
	}

	.link-col a {
		display: block;
		font-size: 0.9rem;
		color: var(--text-muted);
		text-decoration: none;
		margin-bottom: 0.75rem;
		transition: color 0.2s;
	}

	.link-col a:hover {
		color: var(--primary);
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		padding-top: 2rem;
		border-top: 1px solid var(--border);
		font-size: 0.85rem;
		color: var(--text-muted);
	}

	.socials {
		display: flex;
		gap: 1.5rem;
	}

	/* Pricing */
	.pricing-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.pricing-card {
		padding: 3rem;
		border: 1px solid var(--border);
		border-radius: 32px;
		background: white;
		display: flex;
		flex-direction: column;
		position: relative;
	}

	.pricing-card.featured {
		border-color: var(--accent);
		box-shadow: 0 20px 40px rgba(67, 97, 238, 0.1);
		transform: scale(1.05);
		z-index: 10;
	}

	.p-badge {
		position: absolute;
		top: 1.5rem;
		right: 1.5rem;
		background: var(--accent);
		color: white;
		font-size: 0.7rem;
		font-weight: 800;
		padding: 0.3rem 0.8rem;
		border-radius: 9999px;
	}

	.pricing-card h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}

	.price {
		font-size: 3rem;
		font-weight: 800;
		margin-bottom: 1rem;
	}

	.price span {
		font-size: 1.25rem;
		font-weight: 500;
		color: var(--text-muted);
	}

	.pricing-card p {
		margin-bottom: 2rem;
	}

	.pricing-card ul {
		list-style: none;
		margin-bottom: 3rem;
		flex-grow: 1;
	}

	.pricing-card ul li {
		margin-bottom: 1rem;
		font-size: 0.95rem;
		color: var(--text-muted);
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.pricing-card ul li::before {
		content: "✓";
		color: var(--accent);
		font-weight: 800;
	}

	/* Expertise */
	.expertise-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2.5rem;
	}

	.exp-item {
		padding: 3rem;
		border: 1px solid var(--border);
		border-radius: 32px;
		background: #FAFAFA;
	}

	.exp-item h4 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}

	.tech-tags {
		display: flex;
		gap: 0.5rem;
		margin-top: 1.5rem;
		flex-wrap: wrap;
	}

	.tech-tags span {
		background: white;
		border: 1px solid var(--border);
		padding: 0.3rem 0.8rem;
		border-radius: 9999px;
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--primary);
	}

	/* Process */
	.process-steps {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 2rem;
	}

	.step-num {
		font-size: 3rem;
		font-weight: 900;
		color: var(--accent);
		opacity: 0.5;
		margin-bottom: 1.5rem;
	}

	.step h4 {
		color: white;
		font-size: 1.25rem;
		margin-bottom: 1rem;
	}

	.step p {
		color: rgba(255,255,255,0.6);
		font-size: 0.95rem;
	}

	/* Tablet/Mobile */
	@media (max-width: 1024px) {
		.features-grid, .pricing-grid, .expertise-grid { grid-template-columns: repeat(2, 1fr); }
		.process-steps { grid-template-columns: repeat(2, 1fr); gap: 3rem; }
		.pricing-card.featured { transform: scale(1); }
		.footer-grid { grid-template-columns: 1fr; }
	}

	@media (max-width: 768px) {
		.nav-links, .nav-actions .login { display: none; }
		.hero h1 { font-size: 3.5rem; }
		.features-grid, .testimonial-grid, .pricing-grid, .f-links, .expertise-grid, .process-steps { grid-template-columns: 1fr; }
		.hero-visual, .globe-wrap { height: 300px; width: 300px; }
