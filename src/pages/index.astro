---
import Layout from '../layouts/Layout.astro';
import { Zap, BarChart3, Globe, Shield, MessageSquare, ArrowRight } from 'lucide-astro';
---

<Layout title="Balescepat.com | Scaling Human Response with AI Speed">
	<nav>
		<div class="container nav-content">
			<div class="logo">balescepat<span>.</span></div>
			<div class="nav-links">
				<a href="#features">Features</a>
				<a href="#solutions">Solutions</a>
				<a href="#testimonials">Testimonials</a>
				<a href="#pricing">Pricing</a>
			</div>
			<div class="nav-actions">
				<a href="#" class="login">Log in</a>
				<button class="btn btn-primary">Get Started Free</button>
			</div>
		</div>
	</nav>

	<main>
		<!-- Hero Section -->
		<section class="hero">
			<div class="container hero-content">
				<div class="badge-pill">
					<span class="badge-new">v2.0</span>
					<span class="badge-text">Now with advanced AI integration</span>
					<ArrowRight size={14} />
				</div>
				<h1>The ultimate <span>speed</span> for your customer service</h1>
				<p>Scale your business with automated responses that feel human. Join 10,000+ companies using Balescepat to eliminate wait times.</p>
				<div class="hero-actions">
					<button class="btn btn-primary btn-lg">Start Free Trial</button>
					<button class="btn btn-outline btn-lg">Schedule Demo</button>
				</div>
				
				<!-- Interactive Globe Visual -->
				<div class="hero-visual">
					<div class="glow-sphere"></div>
					<div class="globe-wrap">
						<svg viewBox="0 0 100 100" class="globe-svg">
							<defs>
								<pattern id="dotPattern" x="0" y="0" width="3" height="3" patternUnits="userSpaceOnUse">
									<circle cx="0.8" cy="0.8" r="0.4" fill="rgba(67, 97, 238, 0.4)" />
								</pattern>
							</defs>
							<circle cx="50" cy="50" r="48" fill="url(#dotPattern)" class="globe-body" />
							<ellipse cx="50" cy="50" rx="48" ry="15" fill="none" stroke="rgba(67, 97, 238, 0.15)" stroke-width="0.5" transform="rotate(45 50 50)" />
							<ellipse cx="50" cy="50" rx="48" ry="15" fill="none" stroke="rgba(67, 97, 238, 0.15)" stroke-width="0.5" transform="rotate(-45 50 50)" />
						</svg>
					</div>
				</div>
			</div>
		</section>

		<!-- Trust Marquee -->
		<div class="trust-marquee">
			<div class="container">
				<p>TRUSTED BY INNOVATIVE TEAMS WORLDWIDE</p>
				<div class="logo-row">
					<span class="brand">VOYAGER</span>
					<span class="brand">PULSE</span>
					<span class="brand">VERTEX</span>
					<span class="brand">ORBIT</span>
					<span class="brand">NEBULA</span>
					<span class="brand">FLUX</span>
				</div>
			</div>
		</div>

		<!-- Features Grid -->
		<section id="features" class="features">
			<div class="container">
				<div class="section-badge">SOLUTIONS</div>
				<div class="section-title">
					<h2>Built for <span>high-performance</span> teams</h2>
					<p>Stop losing customers to slow response times. Our infrastructure is built to handle millions of messages with sub-second latency.</p>
				</div>
				<div class="features-grid">
					<div class="feature-card">
						<div class="icon-wrap"><Zap /></div>
						<h3>Instant Response</h3>
						<p>Our AI-driven engine responds to customers in under 2 seconds, maintaining a 99% satisfaction rate.</p>
					</div>
					<div class="feature-card">
						<div class="icon-wrap"><Globe /></div>
						<h3>Global Connectivity</h3>
						<p>Integrate seamlessly with WhatsApp, Telegram, Instagram, and more through our unified API.</p>
					</div>
					<div class="feature-card">
						<div class="icon-wrap"><BarChart3 /></div>
						<h3>Deep Analytics</h3>
						<p>Get real-time insights into conversation patterns and team performance with our dashboard.</p>
					</div>
					<div class="feature-card">
						<div class="icon-wrap"><Shield /></div>
						<h3>Enterprise Security</h3>
						<p>SOC2 compliant data handling ensures your customer conversations remain private and secure.</p>
					</div>
					<div class="feature-card">
						<div class="icon-wrap"><MessageSquare /></div>
						<h3>Smart Context</h3>
						<p>Our AI understands the history of every customer interaction to provide relevant, personalized help.</p>
					</div>
					<div class="feature-card">
						<div class="icon-wrap"><ArrowRight /></div>
						<h3>And much more...</h3>
						<p>Discover the full suite of tools designed to help your business scale efficiently.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Dark Testimonials Section -->
		<section id="testimonials" class="testimonials dark-section">
			<div class="container">
				<div class="testimonial-header">
					<div class="section-badge">TESTIMONIALS</div>
					<h2>What leaders are <span>saying</span></h2>
				</div>
				<div class="testimonial-grid">
					<div class="testimonial-card">
						<div class="stars">★★★★★</div>
						<p>"Balescepat transformed our support overnight. We went from a 4-hour response time to 2 minutes without hiring a single person."</p>
						<div class="author">
							<div class="u-avatar"></div>
							<div class="u-info">
								<strong>Alex Rivera</strong>
								<span>CTO at FinTechly</span>
							</div>
						</div>
					</div>
					<div class="testimonial-card">
						<div class="stars">★★★★★</div>
						<p>"The best investment we've made this year. The ROI was clear within the first week of implementation."</p>
						<div class="author">
							<div class="u-avatar"></div>
							<div class="u-info">
								<strong>Sarah Jenkins</strong>
								<span>Head of Ops at CloudScale</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Pricing Section -->
		<section id="pricing" class="pricing">
			<div class="container">
				<div class="section-badge">PRICING</div>
				<div class="section-title">
					<h2>Simple, <span>transparent</span> pricing</h2>
					<p>Choose the plan that's right for your business scale.</p>
				</div>
				<div class="pricing-grid">
					<div class="pricing-card">
						<h3>Starter</h3>
						<div class="price">$0<span>/mo</span></div>
						<p>Perfect for trying out Balescepat.</p>
						<ul>
							<li>1,000 messages / mo</li>
							<li>Basic AI automation</li>
							<li>1 Channel integration</li>
						</ul>
						<button class="btn btn-outline">Get Started</button>
					</div>
					<div class="pricing-card featured">
						<div class="p-badge">MOST POPULAR</div>
						<h3>Professional</h3>
						<div class="price">$49<span>/mo</span></div>
						<p>For growing businesses scaling fast.</p>
						<ul>
							<li>Unlimited messages</li>
							<li>Advanced AI training</li>
							<li>All Channel integrations</li>
							<li>Priority support</li>
						</ul>
						<button class="btn btn-primary">Start Free Trial</button>
					</div>
					<div class="pricing-card">
						<h3>Enterprise</h3>
						<div class="price">Custom</div>
						<p>Fully tailored solutions for big teams.</p>
						<ul>
							<li>Custom AI models</li>
							<li>Dedicated success manager</li>
							<li>SOC2 compliance docs</li>
							<li>SLA guarantee</li>
						</ul>
						<button class="btn btn-outline">Contact Sales</button>
					</div>
				</div>
			</div>
		</section>

		<!-- Final CTA -->
		<section class="cta-section">
			<div class="container">
				<div class="cta-wrapper">
					<h2>Ready to transform your response speed?</h2>
					<p>Join thousands of businesses already scaling with Balescepat.</p>
					<div class="cta-btns">
						<button class="btn btn-primary btn-lg">Get Started Now</button>
						<button class="btn btn-outline btn-lg">Contact Sales</button>
					</div>
				</div>
			</div>
		</section>
	</main>

	<footer>
		<div class="container">
			<div class="footer-grid">
				<div class="f-brand">
					<div class="logo">balescepat<span>.</span></div>
					<p>Leading the revolution in customer communication speed.</p>
				</div>
				<div class="f-links">
					<div class="link-col">
						<h4>Product</h4>
						<a href="#">Features</a>
						<a href="#">Pricing</a>
						<a href="#">Security</a>
					</div>
					<div class="link-col">
						<h4>Company</h4>
						<a href="#">About</a>
						<a href="#">Blog</a>
						<a href="#">Careers</a>
					</div>
					<div class="link-col">
						<h4>Legal</h4>
						<a href="#">Privacy</a>
						<a href="#">Terms</a>
					</div>
				</div>
			</div>
			<div class="footer-bottom">
				<p>&copy; 2024 PT Balescepat Teknologi Nusantara. All rights reserved.</p>
				<div class="socials">
					<a href="#">TW</a>
					<a href="#">LI</a>
					<a href="#">IG</a>
				</div>
			</div>
		</div>
	</footer>
</Layout>

<style>
	/* Navigation */
	nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		background: rgba(255, 255, 255, 0.8);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
		z-index: 1000;
		height: 72px;
		display: flex;
		align-items: center;
	}

	.nav-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
		width: 100%;
	}

	.logo {
		font-size: 1.5rem;
		font-weight: 800;
		letter-spacing: -0.05em;
	}

	.logo span {
		color: var(--accent);
	}

	.nav-links {
		display: flex;
		gap: 2.5rem;
	}

	.nav-links a {
		font-size: 0.95rem;
		font-weight: 500;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.2s;
	}

	.nav-links a:hover {
		color: var(--primary);
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.login {
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
		color: var(--primary);
	}

	/* Hero Section */
	.hero {
		padding: 10rem 0 6rem;
		text-align: center;
	}

	.badge-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		background: #F3F4F6;
		padding: 0.4rem 0.4rem 0.4rem 0.5rem;
		border-radius: 9999px;
		margin-bottom: 2rem;
		border: 1px solid var(--border);
	}

	.badge-new {
		background: var(--primary);
		color: white;
		font-size: 0.75rem;
		font-weight: 700;
		padding: 0.2rem 0.6rem;
		border-radius: 9999px;
	}

	.badge-text {
		font-size: 0.85rem;
		font-weight: 500;
	}

	.hero h1 {
		font-size: clamp(3rem, 10vw, 5.5rem);
		max-width: 900px;
		margin: 0 auto 1.5rem;
	}

	.hero h1 span {
		color: var(--accent);
	}

	.hero p {
		font-size: clamp(1.1rem, 3vw, 1.35rem);
		max-width: 650px;
		margin: 0 auto 3rem;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
	}

	.btn-lg {
		padding: 1rem 2.2rem;
		font-size: 1.05rem;
	}

	/* Globe Visual */
	.hero-visual {
		margin-top: 5rem;
		position: relative;
		height: 450px;
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.glow-sphere {
		position: absolute;
		width: 600px;
		height: 600px;
		background: radial-gradient(circle, var(--glow) 0%, transparent 70%);
		z-index: -1;
	}

	.globe-wrap {
		width: 450px;
		height: 450px;
		animation: float 6s ease-in-out infinite;
	}

	.globe-svg {
		width: 100%;
		height: 100%;
		filter: drop-shadow(0 0 20px rgba(67, 97, 238, 0.1));
		animation: rotate 30s linear infinite;
	}

	@keyframes float {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-20px); }
	}

	@keyframes rotate {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	/* Trust Marquee */
	.trust-marquee {
		padding: 4rem 0;
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
		background: #FAFAFA;
	}

	.trust-marquee p {
		text-align: center;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.2rem;
		margin-bottom: 2.5rem;
	}

	.logo-row {
		display: flex;
		justify-content: space-around;
		align-items: center;
		opacity: 0.4;
	}

	.brand {
		font-weight: 900;
		font-size: 1.5rem;
		letter-spacing: -0.05em;
	}

	/* Features */
	.section-badge {
		color: var(--accent);
		font-weight: 800;
		font-size: 0.8rem;
		letter-spacing: 0.15em;
		margin-bottom: 1.5rem;
	}

	.section-title {
		margin-bottom: 5rem;
	}

	.section-title h2 {
		font-size: clamp(2.5rem, 5vw, 3.5rem);
		margin-bottom: 1.5rem;
	}

	.section-title h2 span {
		color: var(--accent);
	}

	.section-title p {
		font-size: 1.25rem;
		max-width: 700px;
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.feature-card {
		padding: 3rem;
		border: 1px solid var(--border);
		border-radius: 32px;
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		background: white;
	}

	.feature-card:hover {
		transform: translateY(-8px);
		box-shadow: var(--card-shadow);
		border-color: #EEE;
	}

	.icon-wrap {
		width: 56px;
		height: 56px;
		background: #F3F4F6;
		border-radius: 16px;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 2rem;
		color: var(--accent);
	}

	.feature-card h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}

	/* Testimonials */
	.dark-section {
		background: var(--primary);
		color: white;
		border-radius: 64px;
		margin: 2rem;
		padding: 10rem 0;
	}

	.testimonial-header {
		text-align: center;
		margin-bottom: 6rem;
	}

	.testimonial-header h2 {
		font-size: clamp(2.5rem, 5vw, 3.5rem);
	}

	.testimonial-header h2 span {
		color: var(--accent);
	}

	.testimonial-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2.5rem;
	}

	.testimonial-card {
		padding: 3.5rem;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 32px;
	}

	.stars {
		color: var(--accent);
		margin-bottom: 2rem;
		font-size: 1.2rem;
	}

	.testimonial-card p {
		font-size: 1.5rem;
		color: white;
		line-height: 1.4;
		margin-bottom: 3rem;
	}

	.author {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.u-avatar {
		width: 52px;
		height: 52px;
		background: #333;
		border-radius: 50%;
	}

	.u-info strong {
		display: block;
		font-size: 1.1rem;
	}

	.u-info span {
		font-size: 0.9rem;
		opacity: 0.6;
	}

	/* CTA Section */
	.cta-section {
		padding: 12rem 0;
	}

	.cta-wrapper {
		background: linear-gradient(135deg, #F9FAFB 0%, #FFFFFF 100%);
		padding: 8rem 4rem;
		border-radius: 64px;
		text-align: center;
		border: 1px solid var(--border);
	}

	.cta-wrapper h2 {
		font-size: clamp(2.5rem, 5vw, 4rem);
		margin-bottom: 1.5rem;
	}

	.cta-wrapper p {
		font-size: 1.35rem;
		margin-bottom: 3rem;
	}

	.cta-btns {
		display: flex;
		gap: 1rem;
		justify-content: center;
	}

	/* Footer */
	footer {
		padding: 6rem 0 3rem;
		border-top: 1px solid var(--border);
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 2fr 3fr;
		gap: 4rem;
		margin-bottom: 6rem;
	}

	.f-brand p {
		margin-top: 1.5rem;
		max-width: 300px;
	}

	.f-links {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.link-col h4 {
		font-size: 0.95rem;
		margin-bottom: 1.5rem;
	}

	.link-col a {
		display: block;
		font-size: 0.9rem;
		color: var(--text-muted);
		text-decoration: none;
		margin-bottom: 0.75rem;
		transition: color 0.2s;
	}

	.link-col a:hover {
		color: var(--primary);
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		padding-top: 2rem;
		border-top: 1px solid var(--border);
		font-size: 0.85rem;
		color: var(--text-muted);
	}

	.socials {
		display: flex;
		gap: 1.5rem;
	}

	/* Pricing */
	.pricing-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.pricing-card {
		padding: 3rem;
		border: 1px solid var(--border);
		border-radius: 32px;
		background: white;
		display: flex;
		flex-direction: column;
		position: relative;
	}

	.pricing-card.featured {
		border-color: var(--accent);
		box-shadow: 0 20px 40px rgba(67, 97, 238, 0.1);
		transform: scale(1.05);
		z-index: 10;
	}

	.p-badge {
		position: absolute;
		top: 1.5rem;
		right: 1.5rem;
		background: var(--accent);
		color: white;
		font-size: 0.7rem;
		font-weight: 800;
		padding: 0.3rem 0.8rem;
		border-radius: 9999px;
	}

	.pricing-card h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}

	.price {
		font-size: 3rem;
		font-weight: 800;
		margin-bottom: 1rem;
	}

	.price span {
		font-size: 1.25rem;
		font-weight: 500;
		color: var(--text-muted);
	}

	.pricing-card p {
		margin-bottom: 2rem;
	}

	.pricing-card ul {
		list-style: none;
		margin-bottom: 3rem;
		flex-grow: 1;
	}

	.pricing-card ul li {
		margin-bottom: 1rem;
		font-size: 0.95rem;
		color: var(--text-muted);
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.pricing-card ul li::before {
		content: "✓";
		color: var(--accent);
		font-weight: 800;
	}

	/* Tablet/Mobile */
	@media (max-width: 1024px) {
		.features-grid, .pricing-grid { grid-template-columns: repeat(2, 1fr); }
		.pricing-card.featured { transform: scale(1); }
		.footer-grid { grid-template-columns: 1fr; }
	}

	@media (max-width: 768px) {
		.nav-links, .nav-actions .login { display: none; }
		.hero h1 { font-size: 3.5rem; }
		.features-grid, .testimonial-grid, .pricing-grid, .f-links { grid-template-columns: 1fr; }
		.hero-visual, .globe-wrap { height: 300px; width: 300px; }
		.cta-btns { flex-direction: column; }
		.dark-section { margin: 1rem; border-radius: 32px; padding: 6rem 0; }
		.footer-bottom { flex-direction: column; gap: 1.5rem; text-align: center; }
	}
</style>
