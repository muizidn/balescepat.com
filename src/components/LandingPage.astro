---
import { 
	Bot, 
	Code2, 
	LayoutDashboard, 
	GraduationCap, 
	Network, 
	BookOpen, 
	ArrowRight,
	Calendar
} from 'lucide-astro';
import { useTranslations } from '../i18n/utils';
import business from '../../business.json';

interface Props {
  lang: 'en' | 'id';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const formatTitle = (text: string) => {
    return text.replace(/<blue>(.*?)<\/blue>/g, '<span>$1</span>');
};
---

<nav>
    <div class="container nav-content">
        <a href={lang === 'en' ? '/' : '/id'} class="logo">balescepat<span>.</span></a>
        <div class="nav-links">
            <a href="#offerings">{t('nav.offerings')}</a>
            <a href={lang === 'en' ? '/portfolio' : '/id/portfolio'}>{t('nav.portfolio')}</a>
            <a href="#expertise">{t('nav.expertise')}</a>
            <a href="#process">{t('nav.process')}</a>
            <a href="#contact">{t('nav.contact')}</a>
        </div>
        <div class="nav-actions">
            <div class="lang-switcher">
                <a href="/" class={lang === 'en' ? 'active' : ''}>EN</a>
                <span>/</span>
                <a href="/id" class={lang === 'id' ? 'active' : ''}>ID</a>
            </div>
            <a href={`https://${business.whatsapp}`} target="_blank" class="btn btn-primary">{t('nav.consult')}</a>
        </div>
    </div>
</nav>

<main>
    <!-- Hero Section -->
    <section class="hero">
        <div class="container hero-content">
            <div class="badge-pill">
                <span class="badge-new">Enterprise</span>
                <span class="badge-text">{t('hero.badge')}</span>
                <ArrowRight size={14} />
            </div>
            <h1 set:html={formatTitle(t('hero.title'))}></h1>
            <p>{t('hero.desc')}</p>
            <div class="hero-actions">
                <a href={`https://${business.whatsapp}`} target="_blank" class="btn btn-primary btn-lg">{t('hero.cta.primary')}</a>
                <a href="#offerings" class="btn btn-outline btn-lg">{t('hero.cta.secondary')}</a>
            </div>
        </div>
    </section>

    <!-- Service Offerings Grid -->
    <section id="offerings" class="features">
        <div class="container">
            <div class="section-badge">{t('offerings.badge')}</div>
            <div class="section-title">
                <h2 set:html={formatTitle(t('offerings.title'))}></h2>
                <p>{t('offerings.desc')}</p>
            </div>
            <div class="features-grid">
                <div class="feature-card">
                    <div class="icon-wrap"><Bot /></div>
                    <h3>{t('offering.1.title')}</h3>
                    <p>{t('offering.1.desc')}</p>
                </div>
                <div class="feature-card">
                    <div class="icon-wrap"><Code2 /></div>
                    <h3>{t('offering.2.title')}</h3>
                    <p>{t('offering.2.desc')}</p>
                </div>
                <div class="feature-card">
                    <div class="icon-wrap"><LayoutDashboard /></div>
                    <h3>{t('offering.3.title')}</h3>
                    <p>{t('offering.3.desc')}</p>
                </div>
                <div class="feature-card">
                    <div class="icon-wrap"><GraduationCap /></div>
                    <h3>{t('offering.4.title')}</h3>
                    <p>{t('offering.4.desc')}</p>
                </div>
                <div class="feature-card">
                    <div class="icon-wrap"><Network /></div>
                    <h3>{t('offering.5.title')}</h3>
                    <p>{t('offering.5.desc')}</p>
                </div>
                <div class="feature-card">
                    <div class="icon-wrap"><BookOpen /></div>
                    <h3>{t('offering.6.title')}</h3>
                    <p>{t('offering.6.desc')}</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Expertise Section -->
    <section id="expertise" class="expertise">
        <div class="container">
            <div class="section-badge">{t('expertise.badge')}</div>
            <div class="section-title">
                <h2 set:html={formatTitle(t('expertise.title'))}></h2>
                <p>{t('expertise.desc')}</p>
            </div>
            <div class="expertise-grid">
                <div class="exp-item">
                    <h4>{t('expertise.1.title')}</h4>
                    <p>{t('expertise.1.desc')}</p>
                    <div class="tech-tags">
                        <span>Python</span><span>PyTorch</span><span>LangChain</span>
                    </div>
                </div>
                <div class="exp-item">
                    <h4>{t('expertise.2.title')}</h4>
                    <p>{t('expertise.2.desc')}</p>
                    <div class="tech-tags">
                        <span>Bun</span><span>Go</span><span>Rust</span><span>C++</span>
                    </div>
                </div>
                <div class="exp-item">
                    <h4>{t('expertise.3.title')}</h4>
                    <p>{t('expertise.3.desc')}</p>
                    <div class="tech-tags">
                        <span>Kubernetes</span><span>Docker</span><span>Terraform</span>
                    </div>
                </div>
                <div class="exp-item">
                    <h4>{t('expertise.4.title')}</h4>
                    <p>{t('expertise.4.desc')}</p>
                    <div class="tech-tags">
                        <span>Astro</span><span>React</span><span>TypeScript</span><span>Vite</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Our Process Section -->
    <section id="process" class="process dark-section">
        <div class="container">
            <div class="section-badge">{t('process.badge')}</div>
            <div class="section-header-center">
                <h2 style="color: white;" set:html={formatTitle(t('process.title'))}></h2>
            </div>
            <div class="process-steps">
                <div class="step">
                    <div class="step-num">01</div>
                    <h4>{t('process.1.title')}</h4>
                    <p>{t('process.1.desc')}</p>
                </div>
                <div class="step">
                    <div class="step-num">02</div>
                    <h4>{t('process.2.title')}</h4>
                    <p>{t('process.2.desc')}</p>
                </div>
                <div class="step">
                    <div class="step-num">03</div>
                    <h4>{t('process.3.title')}</h4>
                    <p>{t('process.3.desc')}</p>
                </div>
                <div class="step">
                    <div class="step-num">04</div>
                    <h4>{t('process.4.title')}</h4>
                    <p>{t('process.4.desc')}</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Dark Testimonials Section -->
    <section id="testimonials" class="testimonials dark-section">
        <div class="container">
            <div class="testimonial-header">
                <div class="section-badge">{t('testimonial.badge')}</div>
                <h2 set:html={formatTitle(t('testimonial.title'))}></h2>
            </div>
            <div class="testimonial-grid">
                <div class="testimonial-card">
                    <div class="stars">★★★★★</div>
                    <p>{t('testimonial.1.quote')}</p>
                    <div class="author">
                        <div class="u-avatar"></div>
                        <div class="u-info">
                            <strong>Alex Rivera</strong>
                            <span>CTO at FinTechly</span>
                        </div>
                    </div>
                </div>
                <div class="testimonial-card">
                    <div class="stars">★★★★★</div>
                    <p>{t('testimonial.2.quote')}</p>
                    <div class="author">
                        <div class="u-avatar"></div>
                        <div class="u-info">
                            <strong>Sarah Jenkins</strong>
                            <span>Head of Ops at CloudScale</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA -->
    <section id="contact" class="cta-section">
        <div class="container">
            <div class="cta-wrapper">
                <div class="section-badge">{t('cta.badge')}</div>
                <h2 set:html={formatTitle(t('cta.title'))}></h2>
                <p>{t('cta.desc')}</p>
                <div class="cta-btns">
                    <a href={`https://${business.whatsapp}`} target="_blank" class="btn btn-primary btn-lg"><Calendar style="margin-right: 10px;" size={18} /> {t('cta.primary')}</a>
                    <a href={`mailto:${business.email}`} class="btn btn-outline btn-lg">{t('cta.secondary')}</a>
                </div>
            </div>
        </div>
    </section>
</main>

<footer>
    <div class="container">
        <div class="footer-grid">
            <div class="f-brand">
                <div class="logo">balescepat<span>.</span></div>
                <p>{t('footer.desc')}</p>
            </div>
            <div class="f-links">
                <div class="link-col">
                    <h4>{t('footer.expertise')}</h4>
                    <a href="#">{t('footer.expertise.ai')}</a>
                    <a href="#">{t('footer.expertise.software')}</a>
                    <a href="#">{t('footer.expertise.security')}</a>
                </div>
                <div class="link-col">
                    <h4>{t('footer.offerings')}</h4>
                    <a href="#">{t('footer.offerings.whitelabel')}</a>
                    <a href="#">{t('footer.offerings.training')}</a>
                    <a href="#">{t('footer.offerings.lms')}</a>
                </div>
                <div class="link-col">
                    <h4>{t('footer.connect')}</h4>
                    <a href="#">{t('footer.connect.linkedin')}</a>
                    <a href="#">{t('footer.connect.github')}</a>
                    <a href={`https://${business.whatsapp}`} target="_blank">{t('footer.connect.contact')}</a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; {new Date().getFullYear()} {business.name}. {t('footer.rights')}</p>
            <div class="socials">
                <a href="#">TW</a>
                <a href="#">LI</a>
                <a href="#">IG</a>
            </div>
        </div>
    </div>
</footer>

<style>
	/* Navigation */
	nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		background: rgba(255, 255, 255, 0.8);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
		z-index: 1000;
		height: 72px;
		display: flex;
		align-items: center;
	}

	.nav-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
		width: 100%;
	}

	.logo {
		font-size: 1.5rem;
		font-weight: 800;
		letter-spacing: -0.05em;
		text-decoration: none;
		color: var(--text-main);
	}

	.logo span {
		color: var(--accent);
	}

	.nav-links {
		display: flex;
		gap: 2.5rem;
	}

	.nav-links a {
		font-size: 0.95rem;
		font-weight: 500;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.2s;
	}

	.nav-links a:hover {
		color: var(--primary);
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.lang-switcher {
		display: flex;
		gap: 0.5rem;
		font-size: 0.8rem;
		font-weight: 700;
		color: var(--text-muted);
	}

	.lang-switcher a {
		text-decoration: none;
		color: inherit;
		transition: color 0.2s;
	}

	.lang-switcher a.active {
		color: var(--accent);
	}

	.lang-switcher a:hover {
		color: var(--primary);
	}

	.login {
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
		color: var(--primary);
	}

	/* Hero Section */
	.hero {
		padding: 10rem 0 6rem;
		text-align: center;
	}

	.badge-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		background: #F3F4F6;
		padding: 0.4rem 0.4rem 0.4rem 0.5rem;
		border-radius: 9999px;
		margin-bottom: 2rem;
		border: 1px solid var(--border);
	}

	.badge-new {
		background: var(--primary);
		color: white;
		font-size: 0.75rem;
		font-weight: 700;
		padding: 0.2rem 0.6rem;
		border-radius: 9999px;
	}

	.badge-text {
		font-size: 0.85rem;
		font-weight: 500;
	}

	.hero h1 {
		font-size: clamp(3rem, 10vw, 5.5rem);
		max-width: 900px;
		margin: 0 auto 1.5rem;
	}

	.hero h1 :global(span) {
		color: var(--accent);
	}

	.hero p {
		font-size: clamp(1.1rem, 3vw, 1.35rem);
		max-width: 650px;
		margin: 0 auto 3rem;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
	}

	.btn-lg {
		padding: 1rem 2.2rem;
		font-size: 1.05rem;
	}

	.glow-sphere {
		position: absolute;
		width: 600px;
		height: 600px;
		background: radial-gradient(circle, var(--glow) 0%, transparent 70%);
		z-index: -1;
	}

	.section-badge {
		color: var(--accent);
		font-weight: 800;
		font-size: 0.8rem;
		letter-spacing: 0.15em;
		margin-bottom: 1.5rem;
	}

	.section-title {
		margin-bottom: 5rem;
	}

	.section-header-center {
		text-align: center;
		margin-bottom: 5rem;
	}

	.section-header-center h2 :global(span) {
		color: var(--accent);
	}

	.section-title h2 {
		font-size: clamp(2.5rem, 5vw, 3.5rem);
		margin-bottom: 1.5rem;
	}

	.section-title h2 :global(span) {
		color: var(--accent);
	}

	.section-title p {
		font-size: 1.25rem;
		max-width: 700px;
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.feature-card {
		padding: 3rem;
		border: 1px solid var(--border);
		border-radius: 32px;
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		background: white;
	}

	.feature-card:hover {
		transform: translateY(-8px);
		box-shadow: var(--card-shadow);
		border-color: #EEE;
	}

	.icon-wrap {
		width: 56px;
		height: 56px;
		background: #F3F4F6;
		border-radius: 16px;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 2rem;
		color: var(--accent);
	}

	.feature-card h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}

	/* Expertise */
	.expertise-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2.5rem;
	}

	.exp-item {
		padding: 3rem;
		border: 1px solid var(--border);
		border-radius: 32px;
		background: #FAFAFA;
	}

	.exp-item h4 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}

	.tech-tags {
		display: flex;
		gap: 0.5rem;
		margin-top: 1.5rem;
		flex-wrap: wrap;
	}

	.tech-tags span {
		background: white;
		border: 1px solid var(--border);
		padding: 0.3rem 0.8rem;
		border-radius: 9999px;
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--primary);
	}

	/* Process */
	.process-steps {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 2rem;
	}

	.step-num {
		font-size: 3rem;
		font-weight: 900;
		color: var(--accent);
		opacity: 0.5;
		margin-bottom: 1.5rem;
	}

	.step h4 {
		color: white;
		font-size: 1.25rem;
		margin-bottom: 1rem;
	}

	.step p {
		color: rgba(255,255,255,0.6);
		font-size: 0.95rem;
	}

	/* Testimonials */
	.dark-section {
		background: var(--primary);
		color: white;
		border-radius: 64px;
		margin: 2rem;
		padding: 10rem 0;
	}

	.testimonial-header {
		text-align: center;
		margin-bottom: 6rem;
	}

	.testimonial-header h2 {
		font-size: clamp(2.5rem, 5vw, 3.5rem);
	}

	.testimonial-header h2 :global(span) {
		color: var(--accent);
	}

	.testimonial-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2.5rem;
	}

	.testimonial-card {
		padding: 3.5rem;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 32px;
	}

	.stars {
		color: var(--accent);
		margin-bottom: 2rem;
		font-size: 1.2rem;
	}

	.testimonial-card p {
		font-size: 1.5rem;
		color: white;
		line-height: 1.4;
		margin-bottom: 3rem;
	}

	.author {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.u-avatar {
		width: 52px;
		height: 52px;
		background: #333;
		border-radius: 50%;
	}

	.u-info strong {
		display: block;
		font-size: 1.1rem;
	}

	.u-info span {
		font-size: 0.9rem;
		opacity: 0.6;
	}

	/* CTA Section */
	.cta-section {
		padding: 12rem 0;
	}

	.cta-wrapper {
		background: linear-gradient(135deg, #F9FAFB 0%, #FFFFFF 100%);
		padding: 8rem 4rem;
		border-radius: 64px;
		text-align: center;
		border: 1px solid var(--border);
	}

	.cta-wrapper h2 {
		font-size: clamp(2.5rem, 5vw, 4rem);
		margin-bottom: 1.5rem;
	}

	.cta-wrapper h2 :global(span) {
		color: var(--accent);
	}

	.cta-wrapper p {
		font-size: 1.35rem;
		margin-bottom: 3rem;
	}

	.cta-btns {
		display: flex;
		gap: 1rem;
		justify-content: center;
	}

	/* Footer */
	footer {
		padding: 6rem 0 3rem;
		border-top: 1px solid var(--border);
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 2fr 3fr;
		gap: 4rem;
		margin-bottom: 6rem;
	}

	.f-brand p {
		margin-top: 1.5rem;
		max-width: 300px;
	}

	.f-links {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.link-col h4 {
		font-size: 0.95rem;
		margin-bottom: 1.5rem;
	}

	.link-col a {
		display: block;
		font-size: 0.9rem;
		color: var(--text-muted);
		text-decoration: none;
		margin-bottom: 0.75rem;
		transition: color 0.2s;
	}

	.link-col a:hover {
		color: var(--primary);
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		padding-top: 2rem;
		border-top: 1px solid var(--border);
		font-size: 0.85rem;
		color: var(--text-muted);
	}

	.socials {
		display: flex;
		gap: 1.5rem;
	}

	/* Tablet/Mobile */
	@media (max-width: 1024px) {
		.features-grid, .expertise-grid { grid-template-columns: repeat(2, 1fr); }
		.process-steps { grid-template-columns: repeat(2, 1fr); gap: 3rem; }
		.footer-grid { grid-template-columns: 1fr; }
	}

	@media (max-width: 768px) {
		.nav-links { display: none; }
		.hero h1 { font-size: 3.5rem; }
		.features-grid, .testimonial-grid, .f-links, .expertise-grid, .process-steps { grid-template-columns: 1fr; }
		.cta-btns { flex-direction: column; }
		.dark-section { margin: 1rem; border-radius: 32px; padding: 6rem 0; }
		.footer-bottom { flex-direction: column; gap: 1.5rem; text-align: center; }
		.step { text-align: center; }
	}
</style>
